{
  "name": "@aicart/merchant-skill",
  "version": "0.1.0",
  "description": "AICart Merchant Skill - AI-powered merchant assistant",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "build": "npm run build:templates && npm run build:site",
    "build:templates": "node scripts/build-templates.js",
    "build:site": "node scripts/build-site.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "aicart",
    "merchant",
    "skill",
    "openclaw",
    "a2a",
    "commerce",
    "ai"
  ],
  "author": "IO011 / AICart Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/io011/merchant-skill.git"
  },
  "bugs": {
    "url": "https://github.com/io011/merchant-skill/issues"
  },
  "homepage": "https://github.com/io011/merchant-skill#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "yaml": "^2.4.1",
    "sharp": "^0.33.2",
    "mustache": "^4.2.0",
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "node-cron": "^3.0.3",
    "axios": "^1.6.7",
    "crypto-js": "^4.2.0",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "jest": "^29.7.0",
    "eslint": "^8.57.0",
    "supertest": "^6.3.4"
  },
  "openclaw": {
    "skill": {
      "name": "aicart-merchant",
      "displayName": "AICart Merchant",
      "description": "商户端AI助手",
      "version": "0.1.0",
      "capabilities": [
        "file-watch",
        "scheduled-tasks",
        "http-server"
      ]
    }
  }
}
