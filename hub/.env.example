# AICart Hub Configuration

# Server
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aicart_hub
DB_USER=aicart
DB_PASSWORD=your_secure_password

# Redis (for caching and tag index)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
JWT_SECRET=your_jwt_secret_key_here
API_KEY_SALT=your_api_key_salt_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Merchant Query
MERCHANT_QUERY_TIMEOUT_MS=2000
MAX_CONCURRENT_QUERIES=5

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=*

# WebSocket
WS_HEARTBEAT_INTERVAL_MS=30000
WS_HEARTBEAT_TIMEOUT_MS=60000
